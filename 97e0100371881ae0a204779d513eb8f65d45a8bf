import { readdirSync, existsSync } from 'node:fs'
import * as path from 'node:path'

// Core schema is always included. Premium block schemas are discovered
// dynamically from installed @unblocks/block-* packages.
const unblocksBaseDir = path.join(
  process.cwd(),
  'node_modules',
  '@unblocks',
)

function discoverBlockSchemaPaths(): string[] {
  let results: string[] = []

  let entries: ReturnType<typeof readdirSync> = []
  try {
    entries = readdirSync(unblocksBaseDir, { withFileTypes: true })
  } catch {
    // If @unblocks packages are not installed, just return an empty list.
    return results
  }

  for (const entry of entries) {
    if (!('isDirectory' in entry) || !entry.isDirectory()) continue
    if (!entry.name.startsWith('block-')) continue

    const candidateDir = path.join(unblocksBaseDir, entry.name)
    for (const ext of ['ts', 'js'] as const) {
      const fullSchemaPath = path.join(candidateDir, `schema.${ext}`)
      if (!existsSync(fullSchemaPath)) continue

      // Convert to a project-root-relative path, prefixed with "./"
      let rel = path.relative(process.cwd(), fullSchemaPath).replace(/\\/g, '/')
      if (!rel.startsWith('.')) {
        rel = './' + rel
      }
      results.push(rel)
    }
  }

  return results
}

