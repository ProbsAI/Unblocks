# =============================================================================
# Unblocks.ai — Environment Variables
# Copy this file to .env and fill in the values.
# =============================================================================

# --- Required ---

# PostgreSQL connection URL
DATABASE_URL=postgresql://postgres:password@localhost:5432/unblocks

# Application URL (no trailing slash)
APP_URL=http://localhost:3000

# Secret for signing JWTs and encrypting tokens (min 32 chars)
# Generate with: openssl rand -base64 32
SESSION_SECRET=change-me-to-a-random-string-at-least-32-chars

# --- Redis (optional — for rate limiting + session cache) ---

REDIS_URL=redis://localhost:6379

# --- Stripe (required if billing enabled) ---

STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Email / Resend (required if email enabled) ---

RESEND_API_KEY=re_...

# --- Google OAuth (optional — leave blank to disable) ---

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Unblocks License (optional — controls footer attribution) ---

UNBLOCKS_LICENSE_KEY=
